# Supabase — get these from your project's API settings
# https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-only, never expose to client

# Mapbox — create a public token at https://account.mapbox.com/access-tokens/
# Restrict the token to your domain in production
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your-mapbox-public-token

# Resend — https://resend.com/api-keys
# Add your verified sending domain in Resend settings
RESEND_API_KEY=re_your_resend_api_key

# Email sender address
# Development: use onboarding@resend.dev (Resend's shared testing address, no domain needed)
# Production: set to intake@cashpaysober.com once your domain is verified in Resend
RESEND_FROM_EMAIL=auth@hello.cashpaysober.com
